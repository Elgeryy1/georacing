# --- MySQL / MariaDB connection (required) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=georacing
DB_PASSWORD=change_me
DB_NAME=GeoRacingDB

# --- HTTPS server (optional) ---
# Port the HTTPS API listens on (default: 4010)
PORT=4010

# --- TLS certificate paths (optional, defaults shown) ---
# Paths are relative to the working directory unless absolute.
SSL_KEY_PATH=SSLprivatekey.key
SSL_CERT_PATH=SSLcertificate.crt
SSL_CA_PATH=SSLIntermediateCertificate.crt
