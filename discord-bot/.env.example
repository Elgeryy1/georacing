# --- Discord (required) ---
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_DISCORD_APPLICATION_ID
CHANNEL_ID=DISCORD_CHANNEL_ID_FOR_STATUS_UPDATES

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Groq inference (required) ---
GROQ_API_KEY=YOUR_GROQ_API_KEY
# Optional: override the default model (llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (optional) ---
# Reserved for embedding-based RAG. The bot runs in keyword-search mode without it.
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY
